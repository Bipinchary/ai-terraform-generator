# ============================================================
# Auto-generated by AI-Terraform Generator
# DO NOT EDIT MANUALLY
# Generated: {{ project_name }} | {{ region }}
# Resources: vpc={{ vpc }}, subnets={{ subnets|length }}, ec2={{ ec2_instances|length }}
# ============================================================

# ------------------------------------------------------------
# Variables — edit terraform.tfvars to customise
# ------------------------------------------------------------
variable "project_name" {
  description = "Prefix applied to every resource name"
  type        = string
  default     = "{{ project_name }}"
}

variable "region" {
  description = "AWS region to deploy into"
  type        = string
  default     = "{{ region }}"
}

variable "vpc_cidr" {
  description = "CIDR block for the VPC"
  type        = string
  default     = "{{ vpc_cidr }}"
}

variable "instance_type" {
  description = "EC2 instance type"
  type        = string
  default     = "{{ instance_type }}"
}

# ------------------------------------------------------------
# Provider
# ------------------------------------------------------------
terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.region
}

{% if ec2_instances %}
# ------------------------------------------------------------
# AMI — always fetches the latest Amazon Linux 2023 at apply time
# ------------------------------------------------------------
data "aws_ami" "latest_amazon_linux" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["al2023-ami-2023*-x86_64"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

{% endif %}
{% if vpc %}
# ------------------------------------------------------------
# VPC
# ------------------------------------------------------------
resource "aws_vpc" "main" {
  cidr_block           = var.vpc_cidr
  enable_dns_support   = true
  enable_dns_hostnames = true

  tags = {
    Name      = "${var.project_name}-vpc"
    ManagedBy = "ai-terraform-generator"
  }
}

resource "aws_internet_gateway" "main" {
  vpc_id = aws_vpc.main.id

  tags = {
    Name      = "${var.project_name}-igw"
    ManagedBy = "ai-terraform-generator"
  }
}

resource "aws_route_table" "public" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.main.id
  }

  tags = {
    Name      = "${var.project_name}-rt-public"
    ManagedBy = "ai-terraform-generator"
  }
}

{% endif %}
{% if subnets %}
# ------------------------------------------------------------
# Subnets ({{ subnets|length }} public subnets across AZs)
# ------------------------------------------------------------
{% for subnet in subnets %}
resource "aws_subnet" "public{{ subnet.index }}" {
  vpc_id                  = aws_vpc.main.id
  cidr_block              = "{{ subnet.cidr }}"
  availability_zone       = "${var.region}{{ subnet.az_suffix }}"
  map_public_ip_on_launch = true

  tags = {
    Name      = "${var.project_name}-subnet-public{{ subnet.index }}"
    ManagedBy = "ai-terraform-generator"
  }
}

resource "aws_route_table_association" "public{{ subnet.index }}" {
  subnet_id      = aws_subnet.public{{ subnet.index }}.id
  route_table_id = aws_route_table.public.id
}

{% endfor %}
{% endif %}
{% if ec2_instances %}
# ------------------------------------------------------------
# Security Group
# ------------------------------------------------------------
resource "aws_security_group" "ec2" {
  name        = "${var.project_name}-ec2-sg"
  description = "Security group for EC2 instances"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "SSH access"
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
    description = "Allow all outbound"
  }

  tags = {
    Name      = "${var.project_name}-ec2-sg"
    ManagedBy = "ai-terraform-generator"
  }
}

# ------------------------------------------------------------
# EC2 Instances ({{ ec2_instances|length }} instances, round-robin across subnets)
# ------------------------------------------------------------
{% for instance in ec2_instances %}
resource "aws_instance" "web{{ instance.index }}" {
  ami                    = data.aws_ami.latest_amazon_linux.id
  instance_type          = var.instance_type
  subnet_id              = aws_subnet.public{{ instance.subnet_index }}.id
  vpc_security_group_ids = [aws_security_group.ec2.id]

  root_block_device {
    volume_size           = 20
    volume_type           = "gp3"
    delete_on_termination = true
  }

  tags = {
    Name      = "${var.project_name}-ec2-{{ instance.index }}"
    ManagedBy = "ai-terraform-generator"
  }
}

{% endfor %}
{% endif %}
# ------------------------------------------------------------
# Outputs
# ------------------------------------------------------------
{% if vpc %}
output "vpc_id" {
  description = "ID of the VPC"
  value       = aws_vpc.main.id
}

output "vpc_cidr" {
  description = "CIDR block of the VPC"
  value       = aws_vpc.main.cidr_block
}

{% endif %}
{% for subnet in subnets %}
output "subnet_public{{ subnet.index }}_id" {
  description = "ID of public subnet {{ subnet.index }} ({{ region }}{{ subnet.az_suffix }})"
  value       = aws_subnet.public{{ subnet.index }}.id
}

{% endfor %}
{% if ec2_instances %}
output "security_group_id" {
  description = "ID of the EC2 security group"
  value       = aws_security_group.ec2.id
}

output "ami_id" {
  description = "AMI used for EC2 instances (latest Amazon Linux 2023)"
  value       = data.aws_ami.latest_amazon_linux.id
}

{% endif %}
{% for instance in ec2_instances %}
output "ec2_web{{ instance.index }}_id" {
  description = "Instance ID of EC2 web{{ instance.index }}"
  value       = aws_instance.web{{ instance.index }}.id
}

output "ec2_web{{ instance.index }}_public_ip" {
  description = "Public IP of EC2 web{{ instance.index }}"
  value       = aws_instance.web{{ instance.index }}.public_ip
}

output "ec2_web{{ instance.index }}_private_ip" {
  description = "Private IP of EC2 web{{ instance.index }}"
  value       = aws_instance.web{{ instance.index }}.private_ip
}

{% endfor %}
