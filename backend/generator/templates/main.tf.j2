# ============================================================
# Auto-generated by AI-Terraform Generator
# DO NOT EDIT MANUALLY
# ============================================================

# ------------------------------------------------------------
# Variables
# ------------------------------------------------------------
variable "project_name" {
  description = "Prefix applied to every resource name"
  type        = string
  default     = "{{ project_name }}"
}

variable "region" {
  description = "AWS region"
  type        = string
  default     = "{{ region }}"
}

variable "vpc_cidr" {
  description = "CIDR block for the VPC"
  type        = string
  default     = "{{ vpc_cidr }}"
}

variable "instance_type" {
  description = "EC2 instance type"
  type        = string
  default     = "{{ instance_type }}"
}

# ------------------------------------------------------------
# Provider
# ------------------------------------------------------------
terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.region
}

{% if ec2_instances %}
# ------------------------------------------------------------
# AMI
# ------------------------------------------------------------
data "aws_ami" "latest_amazon_linux" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["al2023-ami-2023*-x86_64"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

{% endif %}
{% if vpc %}
# ------------------------------------------------------------
# VPC
# ------------------------------------------------------------
resource "aws_vpc" "main" {
  cidr_block           = var.vpc_cidr
  enable_dns_support   = true
  enable_dns_hostnames = true

  tags = {
    Name      = "${var.project_name}-vpc"
    ManagedBy = "ai-terraform-generator"
  }
}

resource "aws_internet_gateway" "main" {
  vpc_id = aws_vpc.main.id

  tags = {
    Name      = "${var.project_name}-igw"
    ManagedBy = "ai-terraform-generator"
  }
}

{% endif %}
{% if public_subnets %}
# ------------------------------------------------------------
# Public Subnets
# ------------------------------------------------------------
resource "aws_route_table" "public" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.main.id
  }

  tags = {
    Name      = "${var.project_name}-rt-public"
    ManagedBy = "ai-terraform-generator"
  }
}

{% for subnet in public_subnets %}
resource "aws_subnet" "public{{ subnet.index }}" {
  vpc_id                  = aws_vpc.main.id
  cidr_block              = "{{ subnet.cidr }}"
  availability_zone       = "${var.region}{{ subnet.az_suffix }}"
  map_public_ip_on_launch = true

  tags = {
    Name      = "${var.project_name}-subnet-public{{ subnet.index }}"
    Tier      = "public"
    ManagedBy = "ai-terraform-generator"
  }
}

resource "aws_route_table_association" "public{{ subnet.index }}" {
  subnet_id      = aws_subnet.public{{ subnet.index }}.id
  route_table_id = aws_route_table.public.id
}

{% endfor %}
{% endif %}
{% if private_subnets %}
# ------------------------------------------------------------
# Private Subnets
# ------------------------------------------------------------
{% for subnet in private_subnets %}
resource "aws_subnet" "private{{ subnet.index }}" {
  vpc_id            = aws_vpc.main.id
  cidr_block        = "{{ subnet.cidr }}"
  availability_zone = "${var.region}{{ subnet.az_suffix }}"

  tags = {
    Name      = "${var.project_name}-subnet-private{{ subnet.index }}"
    Tier      = "private"
    ManagedBy = "ai-terraform-generator"
  }
}

{% endfor %}
{% endif %}
{% if nat_gateway %}
# ------------------------------------------------------------
# NAT Gateway (allows private subnets to reach the internet)
# ------------------------------------------------------------
resource "aws_eip" "nat" {
  domain = "vpc"

  tags = {
    Name      = "${var.project_name}-nat-eip"
    ManagedBy = "ai-terraform-generator"
  }
}

resource "aws_nat_gateway" "main" {
  allocation_id = aws_eip.nat.id
  subnet_id     = aws_subnet.public1.id

  tags = {
    Name      = "${var.project_name}-nat"
    ManagedBy = "ai-terraform-generator"
  }

  depends_on = [aws_internet_gateway.main]
}

resource "aws_route_table" "private" {
  vpc_id = aws_vpc.main.id

  route {
    cidr_block     = "0.0.0.0/0"
    nat_gateway_id = aws_nat_gateway.main.id
  }

  tags = {
    Name      = "${var.project_name}-rt-private"
    ManagedBy = "ai-terraform-generator"
  }
}

{% for subnet in private_subnets %}
resource "aws_route_table_association" "private{{ subnet.index }}" {
  subnet_id      = aws_subnet.private{{ subnet.index }}.id
  route_table_id = aws_route_table.private.id
}

{% endfor %}
{% endif %}
{% if ec2_instances %}
# ------------------------------------------------------------
# Security Group — EC2
# ------------------------------------------------------------
resource "aws_security_group" "ec2" {
  name        = "${var.project_name}-ec2-sg"
  description = "Security group for EC2 instances"
  vpc_id      = aws_vpc.main.id

{% if load_balancer %}
  ingress {
    from_port       = 80
    to_port         = 80
    protocol        = "tcp"
    security_groups = [aws_security_group.alb.id]
    description     = "HTTP from ALB only"
  }
{% else %}
  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "SSH"
  }

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "HTTP"
  }
{% endif %}

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name      = "${var.project_name}-ec2-sg"
    ManagedBy = "ai-terraform-generator"
  }
}

{% if not autoscaling %}
# ------------------------------------------------------------
# EC2 Instances
# ------------------------------------------------------------
{% for instance in ec2_instances %}
resource "aws_instance" "web{{ instance.index }}" {
  ami                    = data.aws_ami.latest_amazon_linux.id
  instance_type          = var.instance_type
  subnet_id              = aws_subnet.public{{ instance.subnet_index }}.id
  vpc_security_group_ids = [aws_security_group.ec2.id]

  root_block_device {
    volume_size           = 20
    volume_type           = "gp3"
    delete_on_termination = true
  }

  tags = {
    Name      = "${var.project_name}-ec2-{{ instance.index }}"
    ManagedBy = "ai-terraform-generator"
  }
}

{% endfor %}
{% endif %}
{% endif %}
{% if load_balancer %}
# ------------------------------------------------------------
# Application Load Balancer
# ------------------------------------------------------------
resource "aws_security_group" "alb" {
  name        = "${var.project_name}-alb-sg"
  description = "Security group for ALB"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port   = 80
    to_port     = 80
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "HTTP"
  }

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
    description = "HTTPS"
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name      = "${var.project_name}-alb-sg"
    ManagedBy = "ai-terraform-generator"
  }
}

resource "aws_lb" "main" {
  name               = "${var.project_name}-alb"
  internal           = false
  load_balancer_type = "application"
  security_groups    = [aws_security_group.alb.id]
  subnets            = [{% for subnet in public_subnets %}aws_subnet.public{{ subnet.index }}.id{% if not loop.last %}, {% endif %}{% endfor %}]

  tags = {
    Name      = "${var.project_name}-alb"
    ManagedBy = "ai-terraform-generator"
  }
}

resource "aws_lb_target_group" "main" {
  name     = "${var.project_name}-tg"
  port     = 80
  protocol = "HTTP"
  vpc_id   = aws_vpc.main.id

  health_check {
    path                = "/"
    protocol            = "HTTP"
    matcher             = "200"
    interval            = 30
    timeout             = 5
    healthy_threshold   = 2
    unhealthy_threshold = 2
  }
}

resource "aws_lb_listener" "http" {
  load_balancer_arn = aws_lb.main.arn
  port              = 80
  protocol          = "HTTP"

  default_action {
    type             = "forward"
    target_group_arn = aws_lb_target_group.main.arn
  }
}

{% endif %}
{% if autoscaling %}
# ------------------------------------------------------------
# Auto Scaling Group
# ------------------------------------------------------------
resource "aws_launch_template" "main" {
  name_prefix   = "${var.project_name}-lt-"
  image_id      = data.aws_ami.latest_amazon_linux.id
  instance_type = var.instance_type

  network_interfaces {
    associate_public_ip_address = true
    security_groups             = [aws_security_group.ec2.id]
  }

  block_device_mappings {
    device_name = "/dev/xvda"
    ebs {
      volume_size           = 20
      volume_type           = "gp3"
      delete_on_termination = true
    }
  }

  tag_specifications {
    resource_type = "instance"
    tags = {
      Name      = "${var.project_name}-asg-instance"
      ManagedBy = "ai-terraform-generator"
    }
  }
}

resource "aws_autoscaling_group" "main" {
  name                = "${var.project_name}-asg"
  desired_capacity    = {{ ec2_instances|length }}
  min_size            = 1
  max_size            = {{ [ec2_instances|length * 2, 4]|max }}
  vpc_zone_identifier = [{% for subnet in public_subnets %}aws_subnet.public{{ subnet.index }}.id{% if not loop.last %}, {% endif %}{% endfor %}]

  launch_template {
    id      = aws_launch_template.main.id
    version = "$Latest"
  }

{% if load_balancer %}
  target_group_arns = [aws_lb_target_group.main.arn]
{% endif %}

  tag {
    key                 = "Name"
    value               = "${var.project_name}-asg-instance"
    propagate_at_launch = true
  }
}

{% endif %}
{% if database %}
# ------------------------------------------------------------
# RDS — {{ db_engine }}
# ------------------------------------------------------------
resource "aws_db_subnet_group" "main" {
  name       = "${var.project_name}-db-subnet-group"
  subnet_ids = [{% for subnet in private_subnets %}aws_subnet.private{{ subnet.index }}.id{% if not loop.last %}, {% endif %}{% endfor %}]

  tags = {
    Name      = "${var.project_name}-db-subnet-group"
    ManagedBy = "ai-terraform-generator"
  }
}

resource "aws_security_group" "rds" {
  name        = "${var.project_name}-rds-sg"
  description = "Security group for RDS"
  vpc_id      = aws_vpc.main.id

  ingress {
    from_port       = {{ "3306" if db_engine == "mysql" else "5432" }}
    to_port         = {{ "3306" if db_engine == "mysql" else "5432" }}
    protocol        = "tcp"
    security_groups = [aws_security_group.ec2.id]
    description     = "DB access from EC2 only"
  }

  tags = {
    Name      = "${var.project_name}-rds-sg"
    ManagedBy = "ai-terraform-generator"
  }
}

resource "aws_db_instance" "main" {
  identifier             = "${var.project_name}-db"
  engine                 = "{{ db_engine }}"
  engine_version         = "{{ '8.0' if db_engine == 'mysql' else '15' }}"
  instance_class         = "db.t3.micro"
  allocated_storage      = 20
  storage_type           = "gp3"
  db_name                = replace("${var.project_name}", "-", "_")
  username               = "admin"
  password               = "ChangeMe123!"
  db_subnet_group_name   = aws_db_subnet_group.main.name
  vpc_security_group_ids = [aws_security_group.rds.id]
  multi_az               = false
  skip_final_snapshot    = true
  deletion_protection    = false

  tags = {
    Name      = "${var.project_name}-db"
    ManagedBy = "ai-terraform-generator"
  }
}

{% endif %}
# ------------------------------------------------------------
# Outputs
# ------------------------------------------------------------
{% if vpc %}
output "vpc_id" {
  description = "VPC ID"
  value       = aws_vpc.main.id
}

{% endif %}
{% for subnet in public_subnets %}
output "subnet_public{{ subnet.index }}_id" {
  description = "Public subnet {{ subnet.index }} ID"
  value       = aws_subnet.public{{ subnet.index }}.id
}

{% endfor %}
{% for subnet in private_subnets %}
output "subnet_private{{ subnet.index }}_id" {
  description = "Private subnet {{ subnet.index }} ID"
  value       = aws_subnet.private{{ subnet.index }}.id
}

{% endfor %}
{% if load_balancer %}
output "alb_dns_name" {
  description = "DNS name of the load balancer — use this as your app endpoint"
  value       = aws_lb.main.dns_name
}

{% endif %}
{% if not autoscaling %}
{% for instance in ec2_instances %}
output "ec2_web{{ instance.index }}_public_ip" {
  description = "Public IP of EC2 instance {{ instance.index }}"
  value       = aws_instance.web{{ instance.index }}.public_ip
}

{% endfor %}
{% endif %}
{% if database %}
output "db_endpoint" {
  description = "RDS endpoint — use this in your app config"
  value       = aws_db_instance.main.endpoint
}

output "db_port" {
  description = "RDS port"
  value       = aws_db_instance.main.port
}

{% endif %}
