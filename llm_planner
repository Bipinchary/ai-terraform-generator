import json
import re
import os
from typing import Dict

import boto3
from botocore.exceptions import BotoCoreError, ClientError
from dotenv import load_dotenv

from backend.models import InfrastructureSchema, PlannerResponse

# ── Load environment variables ───────────────────────────────
load_dotenv()

AWS_REGION = os.getenv("AWS_REGION", "us-west-2")

# ── Initialize Bedrock client ───────────────────────────────
bedrock = boto3.client(
    service_name="bedrock-runtime",
    region_name=AWS_REGION
)

# ── Model ID (Claude Haiku) ─────────────────────────────────
MODEL_ID = "anthropic.claude-3-haiku-20240307-v1:0"

# ── System Prompt ───────────────────────────────────────────
SYSTEM_PROMPT = """You are an AWS infrastructure planner.

Return ONLY valid JSON.
No explanation. No extra text.

Rules:
- "vpc" must be true if subnets > 0 or ec2_instances > 0
- "subnets" must be >= 1 if ec2_instances > 0
- Cap subnets at 6 and ec2_instances at 20
- "a couple" = 2, "a few" = 3, "several" = 4

Format EXACTLY:
{
  "relevant": true or false,
  "vpc": true or false,
  "subnets": integer,
  "ec2_instances": integer
}

The output must be valid JSON parseable using json.loads().
"""


# ── Call Bedrock Claude ─────────────────────────────────────
def _call_claude(prompt: str) -> str:
    try:
        response = bedrock.converse(
            modelId=MODEL_ID,
            messages=[
                {"role": "user", "content": [{"text": prompt}]}
            ],
            inferenceConfig={
                "maxTokens": 256,
                "temperature": 0
            },
            system=[{"text": SYSTEM_PROMPT}]
        )

        return response["output"]["message"]["content"][0]["text"].strip()

    except (BotoCoreError, ClientError) as exc:
        raise RuntimeError(f"Bedrock API error: {exc}")


# ── Extract JSON safely ─────────────────────────────────────
def _extract_json(text: str) -> Dict:
    try:
        return json.loads(text)
    except json.JSONDecodeError:
        match = re.search(r"\{.*?\}", text, re.DOTALL)
        if not match:
            raise ValueError(f"No JSON found in LLM response: {text}")
        return json.loads(match.group())


# ── Main function ───────────────────────────────────────────
def prompt_to_architecture(user_prompt: str) -> PlannerResponse:
    try:
        raw_output = _call_claude(user_prompt)

        # 🔍 Debug (remove later if needed)
        print("RAW LLM OUTPUT:", raw_output)

        data = _extract_json(raw_output)

        # ── Relevance check ───────────────────────────────
        if not data.get("relevant", False):
            return PlannerResponse(
                ok=False,
                error=(
                    "Your request doesn't appear to be related to cloud infrastructure. "
                    "Try: 'Create a VPC with 2 subnets and 3 EC2 instances.'"
                ),
            )

        # Remove helper field
        data.pop("relevant", None)

        # ── Validate schema ───────────────────────────────
        architecture = InfrastructureSchema(**data)

        return PlannerResponse(ok=True, architecture=architecture)

    except RuntimeError as exc:
        return PlannerResponse(ok=False, error=str(exc))

    except (ValueError, json.JSONDecodeError) as exc:
        return PlannerResponse(
            ok=False,
            error=f"Invalid JSON from model: {exc}"
        )

    except Exception as exc:
        return PlannerResponse(
            ok=False,
            error=f"Validation failed: {exc}"
        )